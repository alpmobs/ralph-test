{% style %}
  .custom-collections--{{ section.id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
  }

  .custom-collections--{{ section.id }} .custom-collections__header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.heading_spacing }}px;
  }

  .custom-collections--{{ section.id }} .custom-collections__title {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 8px;
  }

  .custom-collections--{{ section.id }} .custom-collections__subheading {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0 0 12px;
    font-weight: 500;
  }

  .custom-collections--{{ section.id }} .custom-collections__description {
    font-size: {{ section.settings.description_size }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
  }

  .custom-collections--{{ section.id }} .custom-collections__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.grid_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .custom-collections--{{ section.id }} .custom-collections__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    }
  }

  .custom-collections--{{ section.id }} .custom-collections__card {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.card_border_radius }}px;
    background-color: {{ section.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .custom-collections--{{ section.id }} .custom-collections__card:hover {
    transform: translateY(-4px);
  }

  .custom-collections--{{ section.id }} .custom-collections__card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .custom-collections--{{ section.id }} .custom-collections__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .custom-collections--{{ section.id }} .custom-collections__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-collections--{{ section.id }} .custom-collections__image-placeholder {
    position: absolute;
    inset: 0;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-collections--{{ section.id }} .custom-collections__image-placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .custom-collections--{{ section.id }} .custom-collections__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity }}) 100%
    );
  }

  .custom-collections--{{ section.id }} .custom-collections__product-count {
    position: absolute;
    top: 16px;
    right: 16px;
    background-color: {{ section.settings.count_background }};
    color: {{ section.settings.count_text_color }};
    padding: 8px 16px;
    border-radius: {{ section.settings.count_border_radius }}px;
    font-size: {{ section.settings.card_count_size }}px;
    font-weight: 600;
    z-index: 2;
  }

  .custom-collections--{{ section.id }} .custom-collections__products-preview {
    position: absolute;
    bottom: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    gap: 8px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 2;
  }

  .custom-collections--{{ section.id }} .custom-collections__card:hover .custom-collections__products-preview {
    opacity: 1;
    transform: translateY(0);
  }

  .custom-collections--{{ section.id }} .custom-collections__preview-item {
    flex: 1;
    aspect-ratio: 1;
    border-radius: {{ section.settings.preview_border_radius }}px;
    overflow: hidden;
    background-color: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .custom-collections--{{ section.id }} .custom-collections__preview-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-collections--{{ section.id }} .custom-collections__preview-placeholder {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-collections--{{ section.id }} .custom-collections__preview-placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .custom-collections--{{ section.id }} .custom-collections__content {
    padding: {{ section.settings.card_padding }}px;
    position: relative;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-title {
    font-size: {{ section.settings.card_title_size }}px;
    color: {{ section.settings.card_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .custom-collections--{{ section.id }} .custom-collections__empty-state {
    text-align: center;
    padding: 60px 20px;
    background-color: #f9f9f9;
    border-radius: {{ section.settings.card_border_radius }}px;
  }

  .custom-collections--{{ section.id }} .custom-collections__empty-text {
    font-size: 16px;
    color: #666;
    margin: 0;
  }
{% endstyle %}

<custom-collections-showcase class="custom-collections custom-collections--{{ section.id }}">
  {% if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank %}
    <div class="custom-collections__header">
      {% if section.settings.heading != blank %}
        <h2 class="custom-collections__title">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="custom-collections__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="custom-collections__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.collections != blank %}
    <div class="custom-collections__grid">
      {% for collection in section.settings.collections %}
        <div class="custom-collections__card">
          <a
            href="{{ collection.url }}"
            class="custom-collections__card-link"
          >
            <div class="custom-collections__image-wrapper">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.featured_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: section.settings.image_aspect_ratio | divided_by: 100 }}"
                  class="custom-collections__image"
                >
              {% else %}
                <div class="custom-collections__image-placeholder">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="custom-collections__overlay"></div>

              {% if section.settings.show_product_count %}
                <div class="custom-collections__product-count">
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    item
                  {% else %}
                    items
                  {% endif %}
                </div>
              {% endif %}

              {% if section.settings.show_preview_items %}
                <div class="custom-collections__products-preview">
                  {% assign preview_limit = section.settings.preview_items_count %}
                  {% for product in collection.products limit: preview_limit %}
                    <div class="custom-collections__preview-item">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 200 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          loading="lazy"
                          width="200"
                          height="200"
                          class="custom-collections__preview-image"
                        >
                      {% else %}
                        <div class="custom-collections__preview-placeholder">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="custom-collections__content">
              <h3 class="custom-collections__card-title">
                {{ collection.title }}
              </h3>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="custom-collections__empty-state">
      <p class="custom-collections__empty-text">
        Next, select collections to showcase
      </p>
    </div>
  {% endif %}
</custom-collections-showcase>

<script>
  (() => {
    if (customElements.get('custom-collections-showcase')) {
      return;
    }

    class CustomCollectionsShowcase extends HTMLElement {
      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const cards = this.querySelectorAll('.custom-collections__card');
        cards.forEach((card) => {
          const link = card.querySelector('.custom-collections__card-link');
          const titleElement = link ? link.querySelector('.custom-collections__card-title') : null;

          if (link && titleElement) {
            const title = titleElement.textContent.trim();
            link.setAttribute('aria-label', `View ${title} collection`);
          }
        });
      }
    }

    customElements.define('custom-collections-showcase', CustomCollectionsShowcase);
  })();
</script>

{% schema %}
{
  "name": "Custom collections",
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below heading",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Content padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Card content"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Title size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Product count"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "range",
      "id": "card_count_size",
      "label": "Count size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "count_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "count_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "count_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Product preview on hover"
    },
    {
      "type": "checkbox",
      "id": "show_preview_items",
      "label": "Show product previews",
      "default": true
    },
    {
      "type": "range",
      "id": "preview_items_count",
      "label": "Number of preview items",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "preview_border_radius",
      "label": "Preview border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Custom collections"
    }
  ]
}
{% endschema %}
