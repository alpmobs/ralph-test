{% liquid
  assign total_cards = 0
  capture cards_markup
    for collection in section.settings.collections
      assign total_cards = total_cards | plus: 1
      assign collection_description = collection.description | strip_html | strip
      if section.settings.card_description_words > 0
        assign collection_description = collection_description | truncatewords: section.settings.card_description_words
      endif
      echo '<div class="custom-collections__card">'
        echo '<div class="custom-collections__image-wrapper">'
          if collection.featured_image != blank
            echo collection.featured_image | image_url: width: 800 | image_tag: class: 'custom-collections__image', loading: 'lazy', widths: '400, 600, 800', alt: collection.featured_image.alt
          elsif collection.image != blank
            echo collection.image | image_url: width: 800 | image_tag: class: 'custom-collections__image', loading: 'lazy', widths: '400, 600, 800', alt: collection.image.alt
          else
            echo '<div class="custom-collections__image-placeholder">'
            echo 'collection-1' | placeholder_svg_tag
            echo '</div>'
          endif

          echo '<div class="custom-collections__overlay"></div>'

          if section.settings.show_product_count
            echo '<div class="custom-collections__product-count">'
            echo collection.products_count
            if collection.products_count == 1
              echo ' item'
            else
              echo ' items'
            endif
            echo '</div>'
          endif
          echo '<div class="custom-collections__content">'
          echo '<h3 class="custom-collections__card-title">'
          echo '<a href="' | append: collection.url | append: '" class="custom-collections__title-link">'
          echo collection.title
          echo '</a>'
          echo '</h3>'

          if section.settings.show_card_description and collection_description != blank
            echo '<div class="custom-collections__card-description rte">'
            echo collection_description
            echo '</div>'
          endif

          if section.settings.show_card_button and section.settings.collection_button_text != blank
            echo '<div class="custom-collections__card-actions">'
            echo '<a href="' | append: collection.url | append: '" class="custom-collections__card-button">'
            echo section.settings.collection_button_text
            echo '</a>'
            echo '</div>'
          endif
        echo '</div>'
        echo '</div>'
      echo '</div>'
    endfor

    for block in section.blocks
      assign total_cards = total_cards | plus: 1
      echo '<div class="custom-collections__card"'
      echo block.shopify_attributes
      echo '>'
        echo '<div class="custom-collections__image-wrapper">'
          if block.settings.image != blank
            echo block.settings.image | image_url: width: 800 | image_tag: class: 'custom-collections__image', loading: 'lazy', widths: '400, 600, 800', alt: block.settings.image.alt
          else
            echo '<div class="custom-collections__image-placeholder">'
            echo 'collection-1' | placeholder_svg_tag
            echo '</div>'
          endif
          echo '<div class="custom-collections__overlay"></div>'
          echo '<div class="custom-collections__content">'
          if block.settings.title != blank
            echo '<h3 class="custom-collections__card-title">'
            if block.settings.link != blank
              echo '<a href="' | append: block.settings.link | append: '" class="custom-collections__title-link">'
              echo block.settings.title
              echo '</a>'
            else
              echo block.settings.title
            endif
            echo '</h3>'
          endif

          if block.settings.description != blank
            echo '<div class="custom-collections__card-description rte">'
            echo block.settings.description
            echo '</div>'
          endif

          if block.settings.button_text != blank and block.settings.link != blank
            echo '<div class="custom-collections__card-actions">'
            echo '<a href="' | append: block.settings.link | append: '" class="custom-collections__card-button">'
            echo block.settings.button_text
            echo '</a>'
            echo '</div>'
          endif
        echo '</div>'
        echo '</div>'
      echo '</div>'
    endfor
  endcapture
%}

{% style %}
  .custom-collections--{{ section.id }} {
    --custom-collections-page-margin: 16px;
    background-color: {{ section.settings.container_background_color }};
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
  }

  .custom-collections--{{ section.id }} .custom-collections__container {
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-collections-page-margin) * 2)));
    margin: 0 auto;
    
  }

  @media screen and (min-width: 750px) {
    .custom-collections--{{ section.id }} {
      --custom-collections-page-margin: 40px;
    }
  }

  .custom-collections--{{ section.id }} .custom-collections__header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.heading_spacing }}px;
  }

  .custom-collections--{{ section.id }} .custom-collections__title {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 8px;
  }

  .custom-collections--{{ section.id }} .custom-collections__subheading {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0 0 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .custom-collections--{{ section.id }} .custom-collections__description {
    font-size: {{ section.settings.description_size }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
  }

  .custom-collections--{{ section.id }} .custom-collections__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.grid_gap }}px;
  }

  .custom-collections--{{ section.id }} .custom-collections__slider {
    position: relative;
    overflow: hidden;
  }

  .custom-collections--{{ section.id }} .custom-collections__slider-shell {
    position: relative;
  }

  .custom-collections--{{ section.id }} .custom-collections__track {
    display: flex;
    gap: {{ section.settings.grid_gap }}px;
    transition: transform 0.4s ease;
  }

  .custom-collections--{{ section.id }} .custom-collections__track .custom-collections__card {
    flex: 0 0 calc((100% - ({{ section.settings.grid_gap }}px * {{ section.settings.columns_desktop | minus: 1 }})) / {{ section.settings.columns_desktop }});
  }

  .custom-collections--{{ section.id }} .custom-collections__card {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.card_border_radius }}px;
    background-color: {{ section.settings.card_background }};
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* .custom-collections--{{ section.id }} .custom-collections__card:hover {
    transform: translateY(-4px);
  } */

  .custom-collections--{{ section.id }} .custom-collections__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .custom-collections--{{ section.id }} .custom-collections__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .custom-collections--{{ section.id }} .custom-collections__card:hover .custom-collections__image {
    transform: scale(1.08);
  }

  .custom-collections--{{ section.id }} .custom-collections__image-placeholder {
    position: absolute;
    inset: 0;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-collections--{{ section.id }} .custom-collections__image-placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .custom-collections--{{ section.id }} .custom-collections__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity }}) 100%
    );
  }

  .custom-collections--{{ section.id }} .custom-collections__product-count {
    position: absolute;
    top: 16px;
    right: 16px;
    background-color: {{ section.settings.count_background }};
    color: {{ section.settings.count_text_color }};
    padding: 8px 16px;
    border-radius: {{ section.settings.count_border_radius }}px;
    font-size: {{ section.settings.card_count_size }}px;
    font-weight: 600;
    z-index: 2;
  }

  .custom-collections--{{ section.id }} .custom-collections__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: #ffffff;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-title {
    font-size: {{ section.settings.card_title_size }}px;
    color: {{ section.settings.card_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .custom-collections--{{ section.id }} .custom-collections__title-link {
    color: inherit;
    text-decoration: none;
  }

  .custom-collections--{{ section.id }} .custom-collections__title-link:hover {
    text-decoration: underline;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-description {
    color: {{ section.settings.card_description_color }};
    font-size: {{ section.settings.card_description_size }}px;
    line-height: 1.5;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-description p {
    margin: 0;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-actions {
    margin-top: auto;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-button,
  .custom-collections--{{ section.id }} .custom-collections__section-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .custom-collections--{{ section.id }} .custom-collections__card-button:hover,
  .custom-collections--{{ section.id }} .custom-collections__section-button:hover {
    background-color: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_hover_text_color }};
  }

  .custom-collections--{{ section.id }} .custom-collections__controls {
    position: absolute;
    top: 50%;
    left: -35px;
    right: -35px;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 0 16px;
    pointer-events: none;
    z-index: 4;
  }

  .custom-collections--{{ section.id }} .custom-collections__arrow {
    display: {% if section.settings.show_arrows %}inline-flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    cursor: pointer;
    pointer-events: auto;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }

  .custom-collections--{{ section.id }} .custom-collections__arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .custom-collections--{{ section.id }} .custom-collections__footer {
    margin-top: {{ section.settings.section_button_spacing }}px;
    text-align: {{ section.settings.section_button_alignment }};
  }

  .custom-collections--{{ section.id }} .custom-collections__empty-state {
    text-align: center;
    padding: 60px 20px;
    background-color: #f9f9f9;
    border-radius: {{ section.settings.card_border_radius }}px;
  }

  .custom-collections--{{ section.id }} .custom-collections__empty-text {
    font-size: 16px;
    color: #666;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .custom-collections--{{ section.id }} .custom-collections__track .custom-collections__card {
      flex-basis: calc((100% - {{ section.settings.grid_gap }}px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .custom-collections--{{ section.id }} .custom-collections__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    }

    .custom-collections--{{ section.id }} .custom-collections__track .custom-collections__card {
      flex-basis: calc((100% - ({{ section.settings.grid_gap }}px * {{ section.settings.columns_mobile | minus: 1 }})) / {{ section.settings.columns_mobile }});
    }

    .custom-collections--{{ section.id }} .custom-collections__controls {
      left: 0;
      right: 0;
    }
  }
{% endstyle %}

<custom-collections-showcase
  class="custom-collections custom-collections--{{ section.id }}"
  data-layout-mode="{{ section.settings.layout_mode }}"
  data-columns-desktop="{{ section.settings.columns_desktop }}"
  data-columns-mobile="{{ section.settings.columns_mobile }}"
  data-total-cards="{{ total_cards }}"
>
  <div class="custom-collections__container">
    {% if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank %}
      <div class="custom-collections__header">
        {% if section.settings.subheading != blank %}
          <div class="custom-collections__subheading">{{ section.settings.subheading }}</div>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="custom-collections__title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="custom-collections__description">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if total_cards > 0 %}
      {% if section.settings.layout_mode == 'slider' %}
        <div class="custom-collections__slider-shell">
          <div class="custom-collections__slider">
            <div class="custom-collections__track">
              {{ cards_markup }}
            </div>
          </div>
          <div class="custom-collections__controls">
            <button class="custom-collections__arrow custom-collections__arrow--prev" aria-label="Previous collections">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button class="custom-collections__arrow custom-collections__arrow--next" aria-label="Next collections">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        </div>
      {% else %}
        <div class="custom-collections__grid">
          {{ cards_markup }}
        </div>
      {% endif %}

      {% if section.settings.show_section_button and section.settings.section_button_text != blank and section.settings.section_button_link != blank %}
        <div class="custom-collections__footer">
          <a href="{{ section.settings.section_button_link }}" class="custom-collections__section-button">
            {{ section.settings.section_button_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="custom-collections__empty-state">
        <p class="custom-collections__empty-text">Select collections or add manual collection cards.</p>
      </div>
    {% endif %}
  </div>
</custom-collections-showcase>

<script>
  (() => {
    if (customElements.get('custom-collections-showcase')) {
      return;
    }

    class CustomCollectionsShowcase extends HTMLElement {
      connectedCallback() {
        this.layoutMode = this.dataset.layoutMode;

        if (this.layoutMode !== 'slider') {
          return;
        }

        this.slider = this.querySelector('.custom-collections__slider');
        this.track = this.querySelector('.custom-collections__track');
        this.cards = this.querySelectorAll('.custom-collections__card');
        this.prevButton = this.querySelector('.custom-collections__arrow--prev');
        this.nextButton = this.querySelector('.custom-collections__arrow--next');
        this.currentIndex = 0;

        if (!this.slider || !this.track || this.cards.length === 0) {
          return;
        }

        this.handleResize = this.onResize.bind(this);
        this.prevButton?.addEventListener('click', () => this.moveSlide(-1));
        this.nextButton?.addEventListener('click', () => this.moveSlide(1));
        window.addEventListener('resize', this.handleResize);

        this.updateMetrics();
        this.updateSlider();
      }

      disconnectedCallback() {
        if (this.handleResize) {
          window.removeEventListener('resize', this.handleResize);
        }
      }

      onResize() {
        this.updateMetrics();
        this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
        this.updateSlider();
      }

      updateMetrics() {
        if (window.innerWidth <= 749) {
          this.visibleCards = Number(this.dataset.columnsMobile) || 1;
        } else if (window.innerWidth <= 989) {
          this.visibleCards = Math.min(2, this.cards.length);
        } else {
          this.visibleCards = Number(this.dataset.columnsDesktop) || 3;
        }

        this.maxIndex = Math.max(this.cards.length - this.visibleCards, 0);
      }

      moveSlide(direction) {
        this.currentIndex = Math.max(0, Math.min(this.currentIndex + direction, this.maxIndex));
        this.updateSlider();
      }

      updateSlider() {
        const firstCard = this.cards[0];
        if (!firstCard) {
          return;
        }

        const cardWidth = firstCard.offsetWidth;
        const gap = parseFloat(getComputedStyle(this.track).columnGap || getComputedStyle(this.track).gap || 0);
        const offset = this.currentIndex * (cardWidth + gap);
        this.track.style.transform = `translateX(-${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.maxIndex;
        }
      }
    }

    customElements.define('custom-collections-showcase', CustomCollectionsShowcase);
  })();
</script>

{% schema %}
{
  "name": "Custom collections",
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Selected collections",
      "limit": 12
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show slider arrows",
      "default": true,
      "visible_if": "{{ section.settings.layout_mode == 'slider' }}"
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below heading",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
