{% style %}
  .custom-featured-products--{{ section.id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    background-color: {{ section.settings.background_color }};
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.heading_spacing }}px;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__subheading {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__title {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 12px;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__description {
    font-size: {{ section.settings.description_size }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.grid_gap }}px;
    margin-top: {{ section.settings.grid_spacing }}px;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__card {
    display: flex;
    flex-direction: column;
    background-color: {{ section.settings.card_background }};
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__image-placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ section.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    z-index: 1;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__info {
    padding: {{ section.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__product-title {
    font-size: {{ section.settings.product_title_size }}px;
    color: {{ section.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__vendor {
    font-size: 12px;
    color: {{ section.settings.vendor_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__price-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__price {
    font-size: {{ section.settings.price_size }}px;
    color: {{ section.settings.price_color }};
    font-weight: 600;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__compare-price {
    font-size: {{ section.settings.price_size | minus: 2 }}px;
    color: {{ section.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .custom-featured-products--{{ section.id }} .custom-featured-products__empty-state p {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .custom-featured-products--{{ section.id }} .custom-featured-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .custom-featured-products--{{ section.id }} .custom-featured-products__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    }

    .custom-featured-products--{{ section.id }} .custom-featured-products__subheading {
      font-size: {{ section.settings.subheading_size | times: 0.8 }}px;
    }

    .custom-featured-products--{{ section.id }} .custom-featured-products__title {
      font-size: {{ section.settings.heading_size | times: 0.7 }}px;
    }

    .custom-featured-products--{{ section.id }} .custom-featured-products__description {
      font-size: {{ section.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<custom-featured-products class="custom-featured-products custom-featured-products--{{ section.id }}">
  <div class="custom-featured-products__container">
    {% if section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank %}
      <div class="custom-featured-products__header">
        {% if section.settings.subheading != blank %}
          <div class="custom-featured-products__subheading">{{ section.settings.subheading }}</div>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="custom-featured-products__title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="custom-featured-products__description">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="custom-featured-products__grid">
      {% if section.settings.product_list != blank %}
        {% for product in section.settings.product_list limit: section.settings.products_to_show %}
          <div class="custom-featured-products__card">
            <a href="{{ product.url }}" class="custom-featured-products__card-link">
              <div class="custom-featured-products__image-wrapper">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="custom-featured-products__image"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="custom-featured-products__image-placeholder">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if section.settings.show_badges %}
                  {% if product.compare_at_price > product.price %}
                    <div class="custom-featured-products__badge">Sale</div>
                  {% elsif product.available == false %}
                    <div class="custom-featured-products__badge">Sold out</div>
                  {% endif %}
                {% endif %}
              </div>

              <div class="custom-featured-products__info">
                {% if section.settings.show_vendor and product.vendor != blank %}
                  <div class="custom-featured-products__vendor">{{ product.vendor }}</div>
                {% endif %}

                <h3 class="custom-featured-products__product-title">{{ product.title }}</h3>

                {% if section.settings.show_price %}
                  <div class="custom-featured-products__price-wrapper">
                    <span class="custom-featured-products__price">{{ product.price | money }}</span>
                    {% if product.compare_at_price > product.price %}
                      <span class="custom-featured-products__compare-price">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <div class="custom-featured-products__empty-state">
          <p>Next, select products to showcase</p>
        </div>
      {% endif %}
    </div>
  </div>
</custom-featured-products>

<script>
  (() => {
    if (customElements.get('custom-featured-products')) {
      return;
    }

    class CustomFeaturedProducts extends HTMLElement {
      connectedCallback() {
        const cards = this.querySelectorAll('.custom-featured-products__card');

        cards.forEach((card) => {
          card.addEventListener('mouseenter', function() {
            this.style.zIndex = '10';
          });

          card.addEventListener('mouseleave', function() {
            this.style.zIndex = '1';
          });
        });
      }
    }

    customElements.define('custom-featured-products', CustomFeaturedProducts);
  })();
</script>

{% schema %}
