{% liquid
  assign benefit_count = section.blocks.size
%}

{% style %}
  .custom-benefits--{{ section.id }} {
    --custom-benefits-page-margin: 16px;
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_vertical }}px 0;
    border-radius: {{ section.settings.border_radius }}px;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__container {
    display: grid;
    grid-template-columns: repeat({{ section.settings.items_per_row_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.gap }}px;
    align-items: center;
    justify-items: center;
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-benefits-page-margin) * 2)));
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .custom-benefits--{{ section.id }} {
      --custom-benefits-page-margin: 40px;
    }
  }

  .custom-benefits--{{ section.id }} .custom-benefits__item {
    display: flex;
    align-items: center;
    gap: {{ section.settings.icon_text_gap }}px;
    text-align: {{ section.settings.text_alignment }};
    width: 100%;
    {% if section.settings.text_alignment == 'center' %}
      flex-direction: column;
      justify-content: center;
    {% endif %}
  }

  .custom-benefits--{{ section.id }} .custom-benefits__icon {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.4;
    margin: 0;
    font-weight: 500;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__description {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  .custom-benefits--{{ section.id }} .custom-benefits__empty {
    text-align: center;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    padding: 12px 0;
  }

  @media screen and (max-width: 749px) {
    .custom-benefits--{{ section.id }} .custom-benefits__container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ section.settings.gap }}px;
      scrollbar-width: none;
      -ms-overflow-style: none;
      scroll-behavior: smooth;
    }

    .custom-benefits--{{ section.id }} .custom-benefits__container::-webkit-scrollbar {
      display: none;
    }

    .custom-benefits--{{ section.id }} .custom-benefits__item {
      flex: 0 0 calc(50% - {{ section.settings.gap | divided_by: 2 }}px);
      scroll-snap-align: start;
    }

    .custom-benefits--{{ section.id }} .custom-benefits__icon {
      width: {{ section.settings.icon_size | times: 0.85 }}px;
      height: {{ section.settings.icon_size | times: 0.85 }}px;
    }

    .custom-benefits--{{ section.id }} .custom-benefits__text {
      font-size: {{ section.settings.text_size | times: 0.9 }}px;
    }

    .custom-benefits--{{ section.id }} .custom-benefits__description {
      font-size: {{ section.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<custom-benefits-bar class="custom-benefits custom-benefits--{{ section.id }}">
  {% if benefit_count > 0 %}
    <div class="custom-benefits__container">
      {% for block in section.blocks %}
        <div
          class="custom-benefits__item custom-scroll-trigger custom-fade-in-up"
          style="--custom-animation-delay: {{ forloop.index0 | times: 120 }}ms;"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            <div class="custom-benefits__icon">
              <img
                src="{{ block.settings.image | image_url: width: 100 }}"
                alt="{{ block.settings.image.alt | escape }}"
                width="100"
                height="100"
                loading="lazy"
              >
            </div>
          {% endif %}

          <div class="custom-benefits__content">
            {% if block.settings.text != blank %}
              <p class="custom-benefits__text">{{ block.settings.text }}</p>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="custom-benefits__description">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="custom-benefits__empty">Add benefit blocks to display your selling points.</div>
  {% endif %}
</custom-benefits-bar>

<script>
  (() => {
    if (customElements.get('custom-benefits-bar')) {
      return;
    }

    class CustomBenefitsBar extends HTMLElement {
      connectedCallback() {
        this.container = this.querySelector('.custom-benefits__container');
        this.autoScrollInterval = null;
        this.isUserScrolling = false;
        this.scrollTimeout = null;
        this.handleResize = this.onResize.bind(this);

        if (this.shouldAutoScroll()) {
          this.setupScrollListeners();
          this.startAutoScroll();
        }

        window.addEventListener('resize', this.handleResize);
      }

      disconnectedCallback() {
        this.stopAutoScroll();
        clearTimeout(this.scrollTimeout);
        window.removeEventListener('resize', this.handleResize);
      }

      shouldAutoScroll() {
        if (!this.container) {
          return false;
        }

        return window.innerWidth <= 749 && this.container.children.length > 2;
      }

      onResize() {
        if (this.shouldAutoScroll()) {
          this.setupScrollListeners();
          this.startAutoScroll();
        } else {
          this.stopAutoScroll();
        }
      }

      setupScrollListeners() {
        if (!this.container || this.container.dataset.listenersBound === 'true') {
          return;
        }

        this.container.dataset.listenersBound = 'true';

        this.container.addEventListener('touchstart', () => {
          this.isUserScrolling = true;
          this.stopAutoScroll();
        });

        this.container.addEventListener('touchend', () => {
          clearTimeout(this.scrollTimeout);
          this.scrollTimeout = setTimeout(() => {
            this.isUserScrolling = false;
            if (this.shouldAutoScroll()) {
              this.startAutoScroll();
            }
          }, 3000);
        });

        this.container.addEventListener('scroll', () => {
          if (!this.isUserScrolling) {
            return;
          }

          clearTimeout(this.scrollTimeout);
          this.scrollTimeout = setTimeout(() => {
            this.isUserScrolling = false;
            if (this.shouldAutoScroll()) {
              this.startAutoScroll();
            }
          }, 3000);
        });
      }

      startAutoScroll() {
        if (this.autoScrollInterval || !this.shouldAutoScroll()) {
          return;
        }

        this.autoScrollInterval = window.setInterval(() => {
          if (this.isUserScrolling || !this.container) {
            return;
          }

          const scrollWidth = this.container.scrollWidth;
          const clientWidth = this.container.clientWidth;
          const currentScroll = this.container.scrollLeft;
          const itemWidth = this.container.querySelector('.custom-benefits__item')?.offsetWidth || 0;

          if (currentScroll + clientWidth >= scrollWidth - 10) {
            this.container.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            this.container.scrollBy({ left: itemWidth + {{ section.settings.gap }}, behavior: 'smooth' });
          }
        }, 3000);
      }

      stopAutoScroll() {
        if (this.autoScrollInterval) {
          window.clearInterval(this.autoScrollInterval);
          this.autoScrollInterval = null;
        }
      }
    }

    customElements.define('custom-benefits-bar', CustomBenefitsBar);
  })();
</script>

{% schema %}
{
  "name": "Custom homepage benefits",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "items_per_row_desktop",
      "label": "Items per row on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Gap between icon and text",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Fast shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Custom homepage benefits",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "text": "Secure checkout" } },
        { "type": "benefit", "settings": { "text": "1 year warranty" } },
        { "type": "benefit", "settings": { "text": "Quality guarantee" } }
      ]
    }
  ]
}
{% endschema %}
