{% style %}
  .custom-footer--{{ section.id }} {
    --custom-footer-page-margin: 16px;
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__main {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__content-wrapper {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}px;
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-footer-page-margin) * 2)));
    margin: 0 auto;
  }

  .custom-footer--{{ section.id }} .custom-footer__column {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_spacing }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__image {
    width: 100%;
    max-width: {{ section.settings.column_1_image_width }}px;
    height: auto;
    display: block;
  }

  .custom-footer--{{ section.id }} .custom-footer__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 {{ section.settings.heading_spacing }}px;
    color: {{ section.settings.heading_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__text {
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .custom-footer--{{ section.id }} .custom-footer__text p {
    margin: 0 0 {{ section.settings.item_spacing }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__text p:last-child {
    margin-bottom: 0;
  }

  .custom-footer--{{ section.id }} .custom-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.link_spacing }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__link {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    font-size: {{ section.settings.text_size }}px;
    transition: color 0.2s ease;
  }

  .custom-footer--{{ section.id }} .custom-footer__link:hover {
    color: {{ section.settings.link_hover_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__contact {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_spacing }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: {{ section.settings.text_size }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__contact-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ section.settings.icon_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__contact-link {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .custom-footer--{{ section.id }} .custom-footer__contact-link:hover {
    color: {{ section.settings.link_hover_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__social {
    display: flex;
    gap: {{ section.settings.social_spacing }}px;
    flex-wrap: wrap;
  }

  .custom-footer--{{ section.id }} .custom-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.social_icon_size }}px;
    height: {{ section.settings.social_icon_size }}px;
    color: {{ section.settings.social_icon_color }};
    background-color: {{ section.settings.social_icon_background }};
    border-radius: {{ section.settings.social_icon_radius }}px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .custom-footer--{{ section.id }} .custom-footer__social-link:hover {
    color: {{ section.settings.social_icon_hover_color }};
    background-color: {{ section.settings.social_icon_hover_background }};
  }

  .custom-footer--{{ section.id }} .custom-footer__social-icon {
    width: calc({{ section.settings.social_icon_size }}px * 0.5);
    height: calc({{ section.settings.social_icon_size }}px * 0.5);
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright {
    border-top: 1px solid {{ section.settings.copyright_border_color }};
    padding: {{ section.settings.copyright_padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.copyright_padding_bottom }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-wrapper {
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-footer-page-margin) * 2)));
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.copyright_row_gap }}px;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: center;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-col-left {
    display: flex;
    justify-content: flex-start;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-col-right {
    display: flex;
    justify-content: flex-end;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 8px 16px;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-link,
  .custom-footer--{{ section.id }} .custom-footer__copyright-links a {
    color: {{ section.settings.copyright_text_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-link:hover,
  .custom-footer--{{ section.id }} .custom-footer__copyright-links a:hover {
    color: {{ section.settings.link_hover_color }};
  }

  .custom-footer--{{ section.id }} .custom-footer__copyright-text {
    font-size: {{ section.settings.copyright_text_size }}px;
    color: {{ section.settings.copyright_text_color }};
    margin: 0;
  }

  .custom-footer--{{ section.id }} .custom-footer__payment-row {
    display: flex;
    justify-content: center;
  }

  .custom-footer--{{ section.id }} .custom-footer__payment-list {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 0;
    margin: 0;
  }

  .custom-footer--{{ section.id }} .custom-footer__payment-item {
    display: flex;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .custom-footer--{{ section.id }} .custom-footer__content-wrapper {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    }

    .custom-footer--{{ section.id }} .custom-footer__main {
      padding: {{ section.settings.padding_top | times: 0.7 }}px {{ section.settings.padding_horizontal | times: 0.7 }}px {{ section.settings.padding_bottom | times: 0.7 }}px;
    }

    .custom-footer--{{ section.id }} .custom-footer__copyright {
      padding: {{ section.settings.copyright_padding_top | times: 0.7 }}px {{ section.settings.padding_horizontal | times: 0.7 }}px {{ section.settings.copyright_padding_bottom | times: 0.7 }}px;
    }

    .custom-footer--{{ section.id }} .custom-footer__copyright-row {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .custom-footer--{{ section.id }} .custom-footer__copyright-col-left,
    .custom-footer--{{ section.id }} .custom-footer__copyright-col-right {
      justify-content: center;
    }
  }

  @media screen and (min-width: 750px) {
    .custom-footer--{{ section.id }} {
      --custom-footer-page-margin: 40px;
    }
  }
{% endstyle %}

<div class="custom-footer custom-footer--{{ section.id }}">
  <div class="custom-footer__main">
    <div class="custom-footer__content-wrapper">
      {% if section.settings.show_column_1 %}
        <div class="custom-footer__column">
          {% if section.settings.column_1_image != blank %}
            <img
              src="{{ section.settings.column_1_image | image_url: width: 400 }}"
              alt="{{ section.settings.column_1_image.alt | escape }}"
              class="custom-footer__image"
              loading="lazy"
              width="{{ section.settings.column_1_image.width }}"
              height="{{ section.settings.column_1_image.height }}"
            >
          {% endif %}
          {% if section.settings.column_1_text != blank %}
            <div class="custom-footer__text">{{ section.settings.column_1_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.show_column_2 %}
        <div class="custom-footer__column">
          {% if section.settings.column_2_heading != blank %}
            <h3 class="custom-footer__heading">{{ section.settings.column_2_heading }}</h3>
          {% endif %}
          {% if section.settings.column_2_menu != blank %}
            <ul class="custom-footer__links">
              {% for link in section.settings.column_2_menu.links %}
                <li>
                  <a href="{{ link.url }}" class="custom-footer__link">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.show_column_3 %}
        <div class="custom-footer__column">
          {% if section.settings.column_3_heading != blank %}
            <h3 class="custom-footer__heading">{{ section.settings.column_3_heading }}</h3>
          {% endif %}
          <div class="custom-footer__contact">
            {% if section.settings.contact_email != blank %}
              <div class="custom-footer__contact-item">
                <svg class="custom-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m2 7 10 7 10-7"></path>
                </svg>
                <a href="mailto:{{ section.settings.contact_email }}" class="custom-footer__contact-link">
                  {{ section.settings.contact_email }}
                </a>
              </div>
            {% endif %}
            {% if section.settings.contact_phone != blank %}
              <div class="custom-footer__contact-item">
                <svg class="custom-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <a href="tel:{{ section.settings.contact_phone }}" class="custom-footer__contact-link">
                  {{ section.settings.contact_phone }}
                </a>
              </div>
            {% endif %}
            {% if section.settings.contact_address != blank %}
              <div class="custom-footer__contact-item">
                <svg class="custom-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <span>{{ section.settings.contact_address }}</span>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if section.settings.show_column_4 %}
        <div class="custom-footer__column">
          {% if section.settings.column_4_heading != blank %}
            <h3 class="custom-footer__heading">{{ section.settings.column_4_heading }}</h3>
          {% endif %}
          <div class="custom-footer__social">
            {% if section.settings.social_facebook != blank %}
              <a href="{{ section.settings.social_facebook }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.social_instagram != blank %}
              <a href="{{ section.settings.social_instagram }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.social_twitter != blank %}
              <a href="{{ section.settings.social_twitter }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="Twitter">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.social_youtube != blank %}
              <a href="{{ section.settings.social_youtube }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="YouTube">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.social_tiktok != blank %}
              <a href="{{ section.settings.social_tiktok }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.social_pinterest != blank %}
              <a href="{{ section.settings.social_pinterest }}" class="custom-footer__social-link" target="_blank" rel="noopener" aria-label="Pinterest">
                <svg class="custom-footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_copyright %}
    <div class="custom-footer__copyright">
      <div class="custom-footer__copyright-wrapper">
        {% if section.settings.copyright_row_1_text != blank or shop.privacy_policy != blank or shop.terms_of_service != blank %}
          <div class="custom-footer__copyright-row">
            <div class="custom-footer__copyright-col-left">
              {% if section.settings.copyright_row_1_text != blank %}
                <p class="custom-footer__copyright-text">{{ section.settings.copyright_row_1_text }}</p>
              {% endif %}
            </div>
            <div class="custom-footer__copyright-col-right">
              <div class="custom-footer__copyright-links">
                <span class="custom-footer__copyright-text">{{ powered_by_link }}</span>
                {% if shop.privacy_policy != blank %}
                  <a href="{{ shop.privacy_policy.url }}" class="custom-footer__copyright-link">Privacy Policy</a>
                {% endif %}
                {% if shop.terms_of_service != blank %}
                  <a href="{{ shop.terms_of_service.url }}" class="custom-footer__copyright-link">Terms</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
        {% if shop.enabled_payment_types.size > 0 %}
          <div class="custom-footer__payment-row">
            <ul class="custom-footer__payment-list" role="list">
              {% for type in shop.enabled_payment_types %}
                <li class="custom-footer__payment-item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
 </div>

{% schema %}
{
  "name": "Custom footer",
  "tag": "footer",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
