{% liquid
  assign slides_count = section.blocks.size
%}

{% style %}
  .custom-hero-slider--{{ section.id }} {
    --custom-hero-page-margin: 16px;
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__track {
    position: relative;
    height: {{ section.settings.slide_height_desktop }}px;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ section.settings.slide_height_desktop }}px;
    width: 100%;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transition: opacity 0.7s ease;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide.is-previous {
    opacity: 1;
    pointer-events: none;
    z-index: 1;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__image,
  .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__image {
    object-fit: cover;
    transform: scale(1.08);
    transition: transform 1.2s ease;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-placeholder {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(1.08);
    transition: transform 1.2s ease;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide.active .custom-hero-slider__image,
  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide.active .custom-hero-slider__image-placeholder {
    transform: scale(1);
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide:hover .custom-hero-slider__image,
  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide:hover .custom-hero-slider__image-placeholder {
    transform: scale(1.08);
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__content-wrapper {
    position: absolute;
    z-index: 2;
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-hero-page-margin) * 2)));
    height: 100%;
    display: flex;
    padding: {{ section.settings.content_padding_top }}px 0 {{ section.settings.content_padding_bottom }}px;
    margin: 0 auto;
    left: 0;
    right: 0;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__content {
    width: 100%;
    max-width: min({{ section.settings.content_max_width }}px, calc(100% - (var(--custom-hero-page-margin) * 2)));
    color: {{ section.settings.text_color }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__content-animate {
    opacity: 0;
    transform: translate3d(0, 32px, 0);
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide.is-animating .custom-hero-slider__content-animate {
    animation: customHeroFadeInUp-{{ section.id }} 0.7s ease forwards;
    animation-delay: var(--custom-hero-delay, 0ms);
  }

  @keyframes customHeroFadeInUp-{{ section.id }} {
    from {
      opacity: 0;
      transform: translate3d(0, 32px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__subheading {
    font-size: {{ section.settings.subheading_size }}px;
    margin: 0 0 16px;
    font-weight: 500;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__title {
    font-size: {{ section.settings.title_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
    color: inherit;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__description {
    font-size: {{ section.settings.description_size }}px;
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__button {
    display: inline-block;
    padding: 14px 32px;
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__button-primary {
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__button-primary:hover {
    background-color: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_hover_text_color }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__button-secondary {
    background-color: {{ section.settings.button_2_background }};
    color: {{ section.settings.button_2_text_color }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__button-secondary:hover {
    background-color: {{ section.settings.button_2_hover_background }};
    color: {{ section.settings.button_2_hover_text_color }};
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__dots {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    opacity: {{ section.settings.dot_opacity }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__dot.active {
    background-color: {{ section.settings.dot_active_color }};
    opacity: 1;
    transform: scale(1.2);
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__dot:hover {
    opacity: 1;
  }

  .custom-hero-slider--{{ section.id }} .custom-hero-slider__empty {
    padding: 80px 20px;
    text-align: center;
    background: #f8f8f8;
  }

  @media screen and (max-width: 749px) {
    .custom-hero-slider--{{ section.id }} .custom-hero-slider__track {
      height: {{ section.settings.slide_height_mobile }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__slide {
      height: {{ section.settings.slide_height_mobile }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-desktop {
      display: none;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-mobile {
      display: block;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__content-wrapper {
      align-items: center !important;
      justify-content: center !important;
      padding: {{ section.settings.content_padding_top | times: 0.25 }}px 0 {{ section.settings.content_padding_bottom | times: 0.25 }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__content {
      text-align: center !important;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__subheading {
      font-size: {{ section.settings.subheading_size | times: 0.8 }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__title {
      font-size: {{ section.settings.title_size | times: 0.6 }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__description {
      font-size: {{ section.settings.description_size | times: 0.9 }}px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__button {
      font-size: {{ section.settings.button_font_size | times: 0.9 }}px;
      padding: 12px 24px;
      text-align: center;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__buttons {
      flex-direction: column;
      align-items: stretch;
      justify-content: center !important;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__dots {
      bottom: 16px;
    }
  }

  @media screen and (min-width: 750px) {
    .custom-hero-slider--{{ section.id }} {
      --custom-hero-page-margin: 40px;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-desktop {
      display: block;
    }

    .custom-hero-slider--{{ section.id }} .custom-hero-slider__image-mobile {
      display: none;
    }
  }
{% endstyle %}

<custom-hero-slider
  class="custom-hero-slider custom-hero-slider--{{ section.id }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-slides="{{ slides_count }}"
>
  {% if slides_count > 0 %}
    <div class="custom-hero-slider__track">
      {% for block in section.blocks %}
        {% liquid
          assign content_position = block.settings.content_position | default: section.settings.content_position
          assign text_alignment = block.settings.text_alignment | default: section.settings.text_alignment

          assign wrapper_align_items = 'center'
          assign wrapper_justify_content = 'center'

          case content_position
            when 'top-left'
              assign wrapper_align_items = 'flex-start'
              assign wrapper_justify_content = 'flex-start'
            when 'top-center'
              assign wrapper_align_items = 'flex-start'
              assign wrapper_justify_content = 'center'
            when 'top-right'
              assign wrapper_align_items = 'flex-start'
              assign wrapper_justify_content = 'flex-end'
            when 'center-left'
              assign wrapper_align_items = 'center'
              assign wrapper_justify_content = 'flex-start'
            when 'center'
              assign wrapper_align_items = 'center'
              assign wrapper_justify_content = 'center'
            when 'center-right'
              assign wrapper_align_items = 'center'
              assign wrapper_justify_content = 'flex-end'
            when 'bottom-left'
              assign wrapper_align_items = 'flex-end'
              assign wrapper_justify_content = 'flex-start'
            when 'bottom-center'
              assign wrapper_align_items = 'flex-end'
              assign wrapper_justify_content = 'center'
            when 'bottom-right'
              assign wrapper_align_items = 'flex-end'
              assign wrapper_justify_content = 'flex-end'
          endcase

          assign buttons_justify = 'flex-start'
          case text_alignment
            when 'center'
              assign buttons_justify = 'center'
            when 'right'
              assign buttons_justify = 'flex-end'
          endcase
        %}
        <div class="custom-hero-slider__slide{% if forloop.first %} active{% endif %}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {% if block.settings.image_desktop %}
            <img
              src="{{ block.settings.image_desktop | image_url: width: 2000 }}"
              alt="{{ block.settings.image_desktop.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image_desktop.width }}"
              height="{{ block.settings.image_desktop.height }}"
              class="custom-hero-slider__image custom-hero-slider__image-desktop"
            >
          {% else %}
            <div class="custom-hero-slider__image-placeholder custom-hero-slider__image-desktop">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.image_mobile %}
            <img
              src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
              alt="{{ block.settings.image_mobile.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image_mobile.width }}"
              height="{{ block.settings.image_mobile.height }}"
              class="custom-hero-slider__image custom-hero-slider__image-mobile"
            >
          {% elsif block.settings.image_desktop %}
            <img
              src="{{ block.settings.image_desktop | image_url: width: 1000 }}"
              alt="{{ block.settings.image_desktop.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image_desktop.width }}"
              height="{{ block.settings.image_desktop.height }}"
              class="custom-hero-slider__image custom-hero-slider__image-mobile"
            >
          {% else %}
            <div class="custom-hero-slider__image-placeholder custom-hero-slider__image-mobile">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="custom-hero-slider__overlay"></div>

          <div
            class="custom-hero-slider__content-wrapper"
            style="align-items: {{ wrapper_align_items }}; justify-content: {{ wrapper_justify_content }};"
          >
            <div class="custom-hero-slider__content" style="text-align: {{ text_alignment }};">
              {% if block.settings.subheading != blank %}
                <div class="custom-hero-slider__subheading custom-hero-slider__content-animate" style="--custom-hero-delay: 100ms;">
                  {{ block.settings.subheading }}
                </div>
              {% endif %}

              {% if block.settings.title != blank %}
                <h2 class="custom-hero-slider__title custom-hero-slider__content-animate" style="--custom-hero-delay: 180ms;">
                  {{ block.settings.title }}
                </h2>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class="custom-hero-slider__description custom-hero-slider__content-animate" style="--custom-hero-delay: 260ms;">
                  {{ block.settings.description }}
                </div>
              {% endif %}

              {% if block.settings.button_text != blank or block.settings.button_2_text != blank %}
                <div
                  class="custom-hero-slider__buttons custom-hero-slider__content-animate"
                  style="--custom-hero-delay: 340ms; justify-content: {{ buttons_justify }};"
                >
                  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                    <a
                      href="{{ block.settings.button_link }}"
                      class="custom-hero-slider__button custom-hero-slider__button-primary"
                    >
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}

                  {% if block.settings.button_2_text != blank and block.settings.button_2_link != blank %}
                    <a
                      href="{{ block.settings.button_2_link }}"
                      class="custom-hero-slider__button custom-hero-slider__button-secondary"
                    >
                      {{ block.settings.button_2_text }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if slides_count > 1 %}
      <div class="custom-hero-slider__dots">
        {% for block in section.blocks %}
          <button
            class="custom-hero-slider__dot{% if forloop.first %} active{% endif %}"
            data-slide="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  {% else %}
    <div class="custom-hero-slider__empty">
      <p>Add slides to the Custom homepage hero section.</p>
    </div>
  {% endif %}
</custom-hero-slider>

<script>
  (() => {
    if (customElements.get('custom-hero-slider')) {
      return;
    }

    class CustomHeroSlider extends HTMLElement {
      connectedCallback() {
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.transitionTimeout = null;
        this.track = this.querySelector('.custom-hero-slider__track');
        this.slides = this.querySelectorAll('.custom-hero-slider__slide');
        this.dots = this.querySelectorAll('.custom-hero-slider__dot');
        this.slideCount = this.slides.length;
        this.autoplaySpeed = Number(this.dataset.autoplaySpeed) || 0;

        if (this.slideCount <= 1 || !this.track) {
          if (this.slideCount === 1 && this.slides[0]) {
            this.restartContentAnimation(this.slides[0]);
          }
          return;
        }

        this.setupEventListeners();
        this.restartContentAnimation(this.slides[this.currentSlide]);
        this.startAutoplay();
      }

      setupEventListeners() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', (event) => {
            const slideIndex = Number(event.currentTarget.dataset.slide);
            this.goToSlide(slideIndex);
            this.resetAutoplay();
          });
        });

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.addEventListener('touchstart', (event) => {
          startX = event.touches[0].clientX;
          currentX = startX;
          isDragging = true;
        });

        this.addEventListener('touchmove', (event) => {
          if (!isDragging) return;
          currentX = event.touches[0].clientX;
        });

        this.addEventListener('touchend', () => {
          if (!isDragging) return;

          isDragging = false;
          const diff = startX - currentX;

          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.nextSlide();
            } else {
              this.prevSlide();
            }

            this.resetAutoplay();
          }
        });
      }

      goToSlide(index) {
        if (index === this.currentSlide || !this.slides[index]) {
          return;
        }

        const previousSlide = this.slides[this.currentSlide];
        const nextSlide = this.slides[index];

        this.currentSlide = index;

        if (this.transitionTimeout) {
          window.clearTimeout(this.transitionTimeout);
          this.transitionTimeout = null;
        }

        this.slides.forEach((slide) => {
          slide.classList.remove('is-previous');
        });

        if (previousSlide) {
          previousSlide.classList.remove('is-animating');
          previousSlide.classList.remove('active');
          previousSlide.classList.add('is-previous');
        }

        nextSlide.classList.add('active');
        nextSlide.classList.remove('is-previous');

        this.restartContentAnimation(nextSlide);

        this.transitionTimeout = window.setTimeout(() => {
          if (previousSlide) {
            previousSlide.classList.remove('is-previous');
          }
          this.transitionTimeout = null;
        }, 700);

        this.dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('active', dotIndex === index);
        });
      }

      restartContentAnimation(slide) {
        if (!slide) return;

        slide.classList.remove('is-animating');
        void slide.offsetWidth;
        slide.classList.add('is-animating');
      }

      nextSlide() {
        this.goToSlide((this.currentSlide + 1) % this.slideCount);
      }

      prevSlide() {
        this.goToSlide((this.currentSlide - 1 + this.slideCount) % this.slideCount);
      }

      startAutoplay() {
        if (this.autoplaySpeed <= 0) {
          return;
        }

        this.autoplayInterval = window.setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      resetAutoplay() {
        if (!this.autoplayInterval) {
          return;
        }

        window.clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.transitionTimeout) {
          window.clearTimeout(this.transitionTimeout);
        }

        if (this.autoplayInterval) {
          window.clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('custom-hero-slider', CustomHeroSlider);
  })();
</script>

{% schema %}
{
  "name": "Custom homepage hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slide_height_desktop",
      "label": "Desktop height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "slide_height_mobile",
      "label": "Mobile height",
      "min": 200,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Default content position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "center-left", "label": "Center left" },
        { "value": "center", "label": "Center" },
        { "value": "center-right", "label": "Center right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Default text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "label": "Content padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "label": "Content padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
