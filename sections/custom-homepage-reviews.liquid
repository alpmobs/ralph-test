{% liquid
  assign review_count = section.blocks.size
  assign use_slider = false
  if review_count > 3
    assign use_slider = true
  endif
%}

{% style %}
  .custom-reviews--{{ section.id }} {
    --custom-reviews-page-margin: 16px;
    background-color: {{ section.settings.container_background_color }};
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    background-color: {{ section.settings.background_color }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__container {
    width: 100%;
    max-width: min(var(--normal-page-width), calc(100% - (var(--custom-reviews-page-margin) * 2)));
    margin: 0 auto;
    
  }

  @media screen and (min-width: 750px) {
    .custom-reviews--{{ section.id }} {
      --custom-reviews-page-margin: 40px;
    }
  }

  .custom-reviews--{{ section.id }} .custom-reviews__header {
    text-align: {{ section.settings.title_alignment }};
    margin-bottom: {{ section.settings.title_spacing }}px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__subheading {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0 0 8px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__title {
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    margin: 0 0 12px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__description {
    font-size: {{ section.settings.description_size }}px;
    color: {{ section.settings.description_color }};
    line-height: 1.6;
    margin: 0;
    max-width: 700px;
  }

  {% case section.settings.title_alignment %}
    {% when 'center' %}
      .custom-reviews--{{ section.id }} .custom-reviews__description {
        margin-left: auto;
        margin-right: auto;
      }
    {% when 'right' %}
      .custom-reviews--{{ section.id }} .custom-reviews__description {
        margin-left: auto;
      }
  {% endcase %}

  .custom-reviews--{{ section.id }} .custom-reviews__wrapper {
    position: relative;
    margin-bottom: {{ section.settings.button_spacing }}px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: {{ section.settings.card_spacing }}px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__slider {
    overflow: hidden;
    position: relative;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__track {
    display: flex;
    gap: {{ section.settings.card_spacing }}px;
    transition: transform 0.5s ease;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__card {
    background-color: {{ section.settings.card_background }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__slider .custom-reviews__card {
    flex: 0 0 calc(33.333% - {{ section.settings.card_spacing | times: 2 | divided_by: 3 }}px);
    min-width: calc(33.333% - {{ section.settings.card_spacing | times: 2 | divided_by: 3 }}px);
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-image,
  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-placeholder {
    width: {{ section.settings.reviewer_image_size }}px;
    height: {{ section.settings.reviewer_image_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-image {
    object-fit: cover;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-placeholder {
    background-color: {{ section.settings.card_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    font-weight: 600;
    font-size: {{ section.settings.reviewer_image_size | divided_by: 2 }}px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-info {
    flex-grow: 1;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__reviewer-name {
    font-size: {{ section.settings.reviewer_name_size }}px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0 0 4px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__stars {
    display: flex;
    gap: 2px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__star {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    fill: {{ section.settings.star_color }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__star--empty {
    fill: {{ section.settings.star_empty_color }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__text {
    font-size: {{ section.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product {
    display: block;
    padding-top: 12px;
    border-top: 1px solid {{ section.settings.card_border_color }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product-image {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product-title {
    font-size: 14px;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    margin: 0 0 4px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product-link:hover .custom-reviews__product-title {
    text-decoration: underline;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__product-price {
    font-size: 13px;
    color: {{ section.settings.text_color }};
    margin: 0;
    opacity: 0.85;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__nav-button {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    border: none;
    cursor: pointer;
    display: {% if section.settings.show_nav_buttons %}flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, opacity 0.3s ease;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__nav-button:hover {
    background-color: {{ section.settings.button_hover_background }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__nav-button:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__dots {
    display: flex;
    gap: 8px;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.card_border_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__dot.active {
    background-color: {{ section.settings.button_background }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__button-wrapper {
    text-align: {{ section.settings.button_alignment }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__button {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .custom-reviews--{{ section.id }} .custom-reviews__button:hover {
    background-color: {{ section.settings.button_hover_background }};
  }

  .custom-reviews--{{ section.id }} .custom-reviews__empty {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .custom-reviews--{{ section.id }} .custom-reviews__slider .custom-reviews__card {
      flex: 0 0 calc(50% - {{ section.settings.card_spacing | divided_by: 2 }}px);
      min-width: calc(50% - {{ section.settings.card_spacing | divided_by: 2 }}px);
    }
  }

  @media screen and (max-width: 749px) {
    .custom-reviews--{{ section.id }} .custom-reviews__grid {
      grid-template-columns: 1fr;
    }

    .custom-reviews--{{ section.id }} .custom-reviews__slider .custom-reviews__card {
      flex: 0 0 100%;
      min-width: 100%;
    }

    .custom-reviews--{{ section.id }} .custom-reviews__title {
      font-size: {{ section.settings.title_size | times: 0.8 }}px;
    }

    .custom-reviews--{{ section.id }} .custom-reviews__subheading {
      font-size: {{ section.settings.subheading_size | times: 0.9 }}px;
    }

    .custom-reviews--{{ section.id }} .custom-reviews__description {
      font-size: {{ section.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<custom-reviews-section
  class="custom-reviews custom-reviews--{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
  data-card-spacing="{{ section.settings.card_spacing }}"
>
  <div class="custom-reviews__container">
    {% if section.settings.subheading != blank or section.settings.section_title != blank or section.settings.description != blank %}
      <div class="custom-reviews__header">
        {% if section.settings.subheading != blank %}
          <p class="custom-reviews__subheading">{{ section.settings.subheading }}</p>
        {% endif %}

        {% if section.settings.section_title != blank %}
          <h2 class="custom-reviews__title">{{ section.settings.section_title }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="custom-reviews__description">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if review_count > 0 %}
      <div class="custom-reviews__wrapper">
        {% if use_slider %}
          <div class="custom-reviews__slider">
            <div class="custom-reviews__track">
        {% else %}
          <div class="custom-reviews__grid">
        {% endif %}

        {% for block in section.blocks %}
          <div class="custom-reviews__card" {{ block.shopify_attributes }}>
            <div class="custom-reviews__reviewer">
              {% if block.settings.reviewer_image != blank %}
                <img
                  src="{{ block.settings.reviewer_image | image_url: width: 200 }}"
                  alt="{{ block.settings.reviewer_name | escape }}"
                  class="custom-reviews__reviewer-image"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="custom-reviews__reviewer-placeholder">
                  {% if block.settings.reviewer_name != blank %}
                    {{ block.settings.reviewer_name | slice: 0 | upcase }}
                  {% else %}
                    ?
                  {% endif %}
                </div>
              {% endif %}

              <div class="custom-reviews__reviewer-info">
                {% if block.settings.reviewer_name != blank %}
                  <h3 class="custom-reviews__reviewer-name">{{ block.settings.reviewer_name }}</h3>
                {% endif %}

                <div class="custom-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {% for star in (1..5) %}
                    <svg
                      class="custom-reviews__star{% if star > block.settings.rating %} custom-reviews__star--empty{% endif %}"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>
              </div>
            </div>

            {% if block.settings.review_text != blank %}
              <p class="custom-reviews__text">{{ block.settings.review_text }}</p>
            {% endif %}

            {% if block.settings.show_product_reference and block.settings.product != blank %}
              <div class="custom-reviews__product">
                <a href="{{ block.settings.product.url }}" class="custom-reviews__product-link">
                  {% if block.settings.product.featured_image %}
                    <img
                      src="{{ block.settings.product.featured_image | image_url: width: 100 }}"
                      alt="{{ block.settings.product.title | escape }}"
                      class="custom-reviews__product-image"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  {% endif %}
                  <div class="custom-reviews__product-info">
                    <p class="custom-reviews__product-title">{{ block.settings.product.title }}</p>
                    <p class="custom-reviews__product-price">{{ block.settings.product.price | money }}</p>
                  </div>
                </a>
              </div>
            {% endif %}
          </div>
        {% endfor %}

        {% if use_slider %}
            </div>
          </div>
          <div class="custom-reviews__nav">
            <button class="custom-reviews__nav-button custom-reviews__nav-button--prev" aria-label="Previous reviews">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <div class="custom-reviews__dots"></div>
            <button class="custom-reviews__nav-button custom-reviews__nav-button--next" aria-label="Next reviews">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {% else %}
          </div>
        {% endif %}
      </div>

      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <div class="custom-reviews__button-wrapper">
          <a href="{{ section.settings.button_link }}" class="custom-reviews__button">
            {{ section.settings.button_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="custom-reviews__empty">
        Add review blocks to display customer reviews
      </div>
    {% endif %}
  </div>
</custom-reviews-section>

<script>
  (() => {
    if (customElements.get('custom-reviews-section')) {
      return;
    }

    class CustomReviewsSection extends HTMLElement {
      connectedCallback() {
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.slider = this.querySelector('.custom-reviews__slider');

        if (!this.slider) {
          return;
        }

        this.track = this.querySelector('.custom-reviews__track');
        this.cards = this.querySelectorAll('.custom-reviews__card');
        this.prevButton = this.querySelector('.custom-reviews__nav-button--prev');
        this.nextButton = this.querySelector('.custom-reviews__nav-button--next');
        this.dotsContainer = this.querySelector('.custom-reviews__dots');
        this.cardSpacing = Number(this.dataset.cardSpacing) || 0;

        if (!this.track || this.cards.length === 0) {
          return;
        }

        this.updateVisibleCards();
        this.createDots();
        this.updateSlider();
        this.bindEvents();

        if (this.dataset.autoplay === 'true') {
          this.startAutoplay();
          this.slider.addEventListener('mouseenter', () => this.stopAutoplay());
          this.slider.addEventListener('mouseleave', () => this.startAutoplay());
        }

        window.addEventListener('resize', this.handleResize);
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', this.handleResize);
      }

      handleResize = () => {
        const previousMax = this.maxSlideIndex;
        this.updateVisibleCards();

        if (previousMax !== this.maxSlideIndex) {
          this.currentSlide = Math.min(this.currentSlide, this.maxSlideIndex);
          this.createDots();
        }

        this.updateSlider();
      };

      bindEvents() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.prevSlide();
            this.stopAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.stopAutoplay();
          });
        }
      }

      updateVisibleCards() {
        if (window.innerWidth <= 749) {
          this.visibleCards = 1;
        } else if (window.innerWidth <= 989) {
          this.visibleCards = 2;
        } else {
          this.visibleCards = 3;
        }

        this.maxSlideIndex = Math.max(this.cards.length - this.visibleCards, 0);
      }

      createDots() {
        if (!this.dotsContainer) {
          return;
        }

        this.dotsContainer.innerHTML = '';

        for (let i = 0; i <= this.maxSlideIndex; i++) {
          const dot = document.createElement('button');
          dot.className = 'custom-reviews__dot';
          dot.setAttribute('aria-label', `Go to review group ${i + 1}`);

          if (i === this.currentSlide) {
            dot.classList.add('active');
          }

          dot.addEventListener('click', () => {
            this.goToSlide(i);
            this.stopAutoplay();
          });

          this.dotsContainer.appendChild(dot);
        }
      }

      updateSlider() {
        if (!this.cards.length) {
          return;
        }

        const cardWidth = this.cards[0].offsetWidth;
        const offset = -(this.currentSlide * (cardWidth + this.cardSpacing));
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentSlide === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentSlide >= this.maxSlideIndex;
        }

        const dots = this.dotsContainer ? this.dotsContainer.querySelectorAll('.custom-reviews__dot') : [];
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide -= 1;
          this.updateSlider();
        }
      }

      nextSlide() {
        if (this.currentSlide < this.maxSlideIndex) {
          this.currentSlide += 1;
        } else if (this.dataset.autoplay === 'true') {
          this.currentSlide = 0;
        }

        this.updateSlider();
      }

      goToSlide(index) {
        this.currentSlide = Math.min(index, this.maxSlideIndex);
        this.updateSlider();
      }

      startAutoplay() {
        if (this.dataset.autoplay !== 'true') {
          return;
        }

        const speed = Number(this.dataset.autoplaySpeed) || 3000;
        this.stopAutoplay();
        this.autoplayInterval = window.setInterval(() => this.nextSlide(), speed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          window.clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('custom-reviews-section', CustomReviewsSection);
  })();
</script>

{% schema %}
{
  "name": "Custom homepage reviews",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Testimonials"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "label": "Title",
      "default": "What our customers say"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Hear from our happy customers about their experience with our products.</p>"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Header spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "container_background_color",
      "label": "Container background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_spacing",
      "label": "Card spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Slider controls"
    },
    {
      "type": "checkbox",
      "id": "show_nav_buttons",
      "label": "Show navigation buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "default": 3000
    },
    {
      "type": "header",
      "content": "Review card style"
    },
    {
      "type": "color",
